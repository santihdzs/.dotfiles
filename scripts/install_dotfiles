#!/usr/bin/env zsh
set -euo pipefail

ROOT="${ROOT:-$(cd "$(dirname "$0")/.." && pwd)}"
OS="$("$ROOT/scripts/helpers/os_detect")"
BACKUP_DIR="$HOME/.dotfiles-backup/$(date +%Y%m%d-%H%M%S)"

mkdir -p "$BACKUP_DIR"

stow_dir() {
  local dir="$1"
  [[ -d "$dir" ]] || return 0

  local pkgs=($(find "$dir" -maxdepth 1 -type d -exec basename {} \; 2>/dev/null | tail -n +2 | sort))
  [[ ${#pkgs[@]} -eq 0 ]] && return 0

  for pkg in "${pkgs[@]}"; do
    echo "[install_dotfiles] -> $pkg (from $dir)"

    # Backup existing files before stowing
    # Use nullglob to handle empty directories gracefully
    setopt NULL_GLOB
    local all_files=("$dir/$pkg"/.* "$dir/$pkg"/*)
    setopt NO_NULL_GLOB
    
    for file in "${all_files[@]}"; do
      [[ -e "$file" ]] || continue
      local rel="${file#$dir/$pkg/}"
      [[ "$rel" == "." || "$rel" == ".." ]] && continue
      local target="$HOME/$rel"
      if [[ -e "$target" && ! -L "$target" ]]; then
        mkdir -p "$BACKUP_DIR/$(dirname "$rel")"
        mv "$target" "$BACKUP_DIR/$rel"
        echo "[install_dotfiles]    backed up: $rel"
      fi
    done

    stow -d "$dir" -t "$HOME" "$pkg"
  done
}

echo "[install_dotfiles] OS=$OS"
echo "[install_dotfiles] Backup dir: $BACKUP_DIR"

cd "$ROOT"

# Common (works on all OS)
stow_dir "$ROOT/stow/common"

# OS-specific
if [[ "$OS" == "linux" ]]; then
  stow_dir "$ROOT/stow/linux"
elif [[ "$OS" == "mac" ]]; then
  stow_dir "$ROOT/stow/mac"
fi

echo "[install_dotfiles] Done."
