#!/usr/bin/env zsh
set -euo pipefail

ROOT="${ROOT:-$(cd "$(dirname "$0")/.." && pwd)}"
OS="$("$ROOT/scripts/helpers/os_detect")"

echo "[bootstrap] OS=$OS"

# tmux plugin manager (TPM)
if [[ ! -d "$HOME/.tmux/plugins/tpm" ]]; then
  echo "[bootstrap] Installing tmux TPM..."
  mkdir -p "$HOME/.tmux/plugins"
  git clone https://github.com/tmux-plugins/tpm "$HOME/.tmux/plugins/tpm"
else
  echo "[bootstrap] TPM already installed"
fi

# bun
if [[ ! -d "$HOME/.bun" ]]; then
  echo "[bootstrap] Installing bun..."
  if ! command -v unzip >/dev/null 2>&1; then
    echo "[bootstrap] Installing unzip..."
    if [[ "$OS" == "mac" ]]; then
      brew install unzip
    elif [[ "$OS" == "linux" ]]; then
      if command -v pacman >/dev/null 2>&1; then
        sudo pacman -S --needed --noconfirm unzip 2>/dev/null || true
      elif command -v apt >/dev/null 2>&1; then
        sudo apt-get install -y unzip 2>/dev/null || true
      fi
    fi
  fi
  curl -fsSL https://bun.sh/install | bash
else
  echo "[bootstrap] bun already installed"
fi

echo "[bootstrap] Done."
